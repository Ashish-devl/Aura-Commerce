{
  "projectInfo": {
    "name": "E-Commerce App",
    "purpose": "A fully functional e-commerce clothing website with secure checkout, inventory, admin, reviews and wishlist."
  },
  "collections": [
    {
      "name": "users",
      "purpose": "Stores user profiles, roles, and wishlists",
      "documentIds": "Firebase Auth UID",
      "fields": [
        { "name": "email", "type": "string", "description": "User email address" },
        { "name": "role", "type": "string", "description": "admin or customer" },
        { "name": "wishlist", "type": "array", "description": "Array of product IDs" },
        { "name": "createdAt", "type": "timestamp" }
      ]
    },
    {
      "name": "products",
      "purpose": "Stores clothing products for sale",
      "documentIds": "Auto-generated",
      "fields": [
        { "name": "name", "type": "string" },
        { "name": "description", "type": "string" },
        { "name": "price", "type": "number" },
        { "name": "currency", "type": "string" },
        { "name": "category", "type": "string" },
        { "name": "imageUrl", "type": "string" },
        { "name": "stock", "type": "number" },
        { "name": "createdAt", "type": "timestamp" },
        { "name": "updatedAt", "type": "timestamp" }
      ]
    },
    {
      "name": "orders",
      "purpose": "Tracks user orders",
      "documentIds": "Auto-generated",
      "fields": [
        { "name": "userId", "type": "string" },
        { "name": "items", "type": "array", "description": "Array of {productId, quantity, price, name}" },
        { "name": "totalAmount", "type": "number" },
        { "name": "status", "type": "string", "description": "pending, processing, shipped, delivered" },
        { "name": "shippingAddress", "type": "map" },
        { "name": "paymentStatus", "type": "string", "description": "pending, completed" },
        { "name": "createdAt", "type": "timestamp" }
      ]
    },
    {
      "name": "reviews",
      "purpose": "Stores product reviews",
      "documentIds": "Auto-generated",
      "fields": [
        { "name": "productId", "type": "string" },
        { "name": "userId", "type": "string" },
        { "name": "userName", "type": "string" },
        { "name": "rating", "type": "number" },
        { "name": "comment", "type": "string" },
        { "name": "createdAt", "type": "timestamp" }
      ]
    }
  ]
}
